<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="four_xh540_mixed">

  <link name="base_link"/>

  <link name="link1">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-4" ixy="0.0" ixz="0.0"
               iyy="1e-4" iyz="0.0"
               izz="1e-4"/>
    </inertial>
  </link>

  <link name="link2">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-4" ixy="0.0" ixz="0.0"
               iyy="1e-4" iyz="0.0"
               izz="1e-4"/>
    </inertial>
  </link>

  <link name="link3">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="1e-4" ixy="0.0" ixz="0.0"
               iyy="1e-4" iyz="0.0"
               izz="1e-4"/>
    </inertial>
  </link>

  <joint name="joint1" type="revolute">
    <parent link="base_link"/>
    <child link="link1"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1000.0" upper="1000.0" effort="10.0" velocity="10.0"/>
  </joint>

  <joint name="joint2" type="revolute">
    <parent link="base_link"/>
    <child link="link2"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1000.0" upper="1000.0" effort="10.0" velocity="10.0"/>
  </joint>

  <joint name="joint3" type="revolute">
    <parent link="base_link"/>
    <child link="link3"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-1000.0" upper="1000.0" effort="10.0" velocity="10.0"/>
  </joint>

  <ros2_control name="dxl_system" type="system">
    <hardware>
      <plugin>dynamixel_hardware_interface/DynamixelHardware</plugin>

      <param name="port_name">/dev/ttyUSB0</param>
      <param name="baud_rate">1000000</param>
      <param name="error_timeout_ms">250</param>
      <param name="dynamixel_model_folder">/param/dxl_model</param>
      <param name="disable_torque_at_init">true</param>

      <param name="dynamixel_state_pub_msg_name">/dynamixel_hardware_interface/dxl_state</param>
      <param name="get_dynamixel_data_srv_name">/dynamixel_hardware_interface/get_dxl_data</param>
      <param name="set_dynamixel_data_srv_name">/dynamixel_hardware_interface/set_dxl_data</param>
      <param name="reboot_dxl_srv_name">/dynamixel_hardware_interface/reboot_dxl</param>
      <param name="set_dxl_torque_srv_name">/dynamixel_hardware_interface/set_dxl_torque</param>

      <param name="number_of_joints">3</param>
      <param name="number_of_transmissions">3</param>

      <param name="transmission_to_joint_matrix">1, 0, 0, 0, 1, 0, 0, 0, 1</param>
      <param name="joint_to_transmission_matrix">1, 0, 0, 0, 1, 0, 0, 0, 1</param>
    </hardware>

    <joint name="joint1">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="joint2">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <joint name="joint3">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <gpio name="dxl1">
      <param name="type">dxl</param>
      <param name="ID">1</param>
      <!-- <param name="dynamixel_model">xh540_w150</param> -->
      <param name="Operating Mode">1</param>
      <command_interface name="Goal Velocity"/>
      <state_interface name="Present Position"/>
      <state_interface name="Present Velocity"/>
      <state_interface name="Present Current"/>
    </gpio>

    <gpio name="dxl2">
      <param name="type">dxl</param>
      <param name="ID">2</param>
      <!-- <param name="dynamixel_model">xh540_w150</param> -->
      <param name="Operating Mode">1</param>
      <command_interface name="Goal Velocity"/>
      <state_interface name="Present Position"/>
      <state_interface name="Present Velocity"/>
      <state_interface name="Present Current"/>
    </gpio>

    <gpio name="dxl3">
      <param name="type">dxl</param>
      <param name="ID">3</param>
      <!-- <param name="dynamixel_model">xh540_w150</param> -->
      <param name="Operating Mode">1</param>
      <command_interface name="Goal Velocity"/>
      <state_interface name="Present Position"/>
      <state_interface name="Present Velocity"/>
      <state_interface name="Present Current"/>
    </gpio>
  </ros2_control>

</robot>
